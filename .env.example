# =============================================================================
# ERP MINIMARKET - Variables de Entorno
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env
# =============================================================================

# --- APLICACIÓN ---
NODE_ENV=development
APP_NAME="ERP Minimarket"
APP_VERSION=1.0.0

# --- BACKEND ---
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
API_PREFIX=/api/v1

# --- FRONTEND ---
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api/v1

# --- BASE DE DATOS PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=erp_minimarket
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=change_this_strong_password_in_production
DATABASE_URL=postgresql://erp_user:change_this_strong_password_in_production@localhost:5432/erp_minimarket

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@localhost:6379

# --- JWT ---
JWT_SECRET=change_this_jwt_secret_min_64_chars_in_production_use_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_min_64_chars_different_from_jwt_secret
JWT_REFRESH_EXPIRES_IN=7d

# --- SEGURIDAD ---
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_LOGIN_MAX=5

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- LOGGING ---
LOG_LEVEL=debug
LOG_FORMAT=json

# --- UPLOADS ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# --- CONFIGURACIÓN DEL NEGOCIO ---
DEFAULT_TAX_RATE=0.18
DEFAULT_CURRENCY=PEN
DEFAULT_CURRENCY_SYMBOL=S/
DEFAULT_LOCALE=es-PE
DEFAULT_TIMEZONE=America/Lima

# --- BACKUP ---
BACKUP_DIR=./backups
BACKUP_SCHEDULE="0 2 * * *"

# --- DOCKER (solo para docker-compose) ---
PGADMIN_EMAIL=admin@minimarket.com
PGADMIN_PASSWORD=admin123
